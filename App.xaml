<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="Kil0bitSystemMonitor.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kil0bitSystemMonitor"
    xmlns:helpers="using:Kil0bitSystemMonitor.Helpers"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
            <helpers:StringFormatConverter x:Key="StringFormatConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
