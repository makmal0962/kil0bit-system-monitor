<Window
    x:Class="Kil0bitSystemMonitor.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    xmlns:local="clr-namespace:Kil0bitSystemMonitor"
    mc:Ignorable="d"
    Title="Kil0bit System Monitor Settings"
    Height="720" Width="1000"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    ui:WindowHelper.UseModernWindowStyle="True"
    ui:ThemeManager.RequestedTheme="Dark">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid x:Name="SettingsRoot" Loaded="SettingsRoot_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:NavigationView x:Name="SettingsNav" 
                        Grid.Row="0"
                        PaneDisplayMode="Left"
                        OpenPaneLength="200"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        SelectionChanged="SettingsNav_SelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Home" Tag="Home" IsSelected="True">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="General" Tag="General">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Setting" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Monitoring" Tag="Monitoring">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="FourBars" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Appearance" Tag="Appearance">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Edit" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="About" Tag="About">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Help" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left" Margin="24">
                    <!-- Home Section -->
                    <StackPanel x:Name="HomeSection" Visibility="Visible">
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock Text="Welcome" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,0,0,4">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.3" ShadowDepth="2"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="Kil0bit System Monitor is active and tracking your hardware performance with near-zero overhead." 
                                       FontSize="17" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" />
                        </StackPanel>

                        <UniformGrid Columns="2" HorizontalAlignment="Left">
                            <!-- General Card -->
                            <Button x:Name="HomeGeneralBtn" Click="HomeCard_Click" Tag="General" Width="280" Height="110" Margin="0,0,16,16" Background="Transparent" BorderThickness="0" Padding="0">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                        BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        Padding="16" CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Setting" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="General" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                                            <TextBlock Text="Startup behavior, updates, and core system settings." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- Monitoring Card -->
                            <Button x:Name="HomeMonitoringBtn" Click="HomeCard_Click" Tag="Monitoring" Width="280" Height="110" Margin="0,0,0,16" Background="Transparent" BorderThickness="0" Padding="0">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                        BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        Padding="16" CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="FourBars" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Monitoring" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                                            <TextBlock Text="Select CPU, GPU, and Network hardware sensors." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- Appearance Card -->
                            <Button x:Name="HomeAppearanceBtn" Click="HomeCard_Click" Tag="Appearance" Width="280" Height="110" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Padding="0">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                        BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        Padding="16" CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Edit" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                                            <TextBlock Text="Customize themes, colors, and font styles." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- About Card -->
                            <Button x:Name="HomeAboutBtn" Click="HomeCard_Click" Tag="About" Width="280" Height="110" Background="Transparent" BorderThickness="0" Padding="0">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                        BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        Padding="16" CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Help" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="About" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                                            <TextBlock Text="Version info, documentation, and support links." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </UniformGrid>

                        <!-- InfoBar Replacement -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="4" Padding="16" Margin="0,20,0,0" BorderBrush="{DynamicResource SystemAccentColorBrush}" BorderThickness="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Accept" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Performance Note" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="Your system is being monitored using low-level Win32 APIs for maximum precision." Opacity="0.8" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- General Section -->
                    <StackPanel x:Name="GeneralSection" Visibility="Collapsed">
                        <TextBlock Text="General" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Column 0 -->
                            <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon Glyph="&#xE7B3;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Show Overlay" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Enable or disable the monitor." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Right" IsOn="{Binding Config.ShowOverlay, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon Glyph="&#xE718;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Lock Position" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Prevent accidental dragging." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Right" IsOn="{Binding Config.LockPosition, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon Glyph="&#xE72A;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Run at Startup" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Launch with Windows." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Right" IsOn="{Binding Config.LaunchOnStartup, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Column 2 -->
                            <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon Glyph="&#xE740;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Hide in Fullscreen" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Hide during games/movies." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Right" IsOn="{Binding Config.HideOnFullscreen, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon Glyph="&#xE90E;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Snap to Taskbar" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Dock to the taskbar area." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Right" IsOn="{Binding Config.StickToTaskbar, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon Glyph="&#xE819;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Keep on Top" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Stay above other windows." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Right" IsOn="{Binding Config.AlwaysOnTop, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Row 3: Performance -->
                            <Border Grid.Row="3" Grid.ColumnSpan="3" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,4,0,12" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="200" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon Glyph="&#xE916;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Refresh Rate" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Set how often the monitor updates its metrics." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    
                                    <ComboBox Grid.Column="2" SelectedValue="{Binding Config.UpdateInterval, Mode=TwoWay}" SelectedValuePath="Tag" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                        <ComboBoxItem Content="500ms (High Performance)">
                                            <ComboBoxItem.Tag>
                                                <sys:Int32>500</sys:Int32>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="1000ms (Default)">
                                            <ComboBoxItem.Tag>
                                                <sys:Int32>1000</sys:Int32>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="2000ms (Relaxed)">
                                            <ComboBoxItem.Tag>
                                                <sys:Int32>2000</sys:Int32>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="5000ms (Power Saver)">
                                            <ComboBoxItem.Tag>
                                                <sys:Int32>5000</sys:Int32>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Monitoring Section -->
                    <StackPanel x:Name="MonitoringSection" Visibility="Collapsed">
                        <TextBlock Text="Monitoring" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: Telemetry Toggles -->
                            <StackPanel Grid.Column="0">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8,8,0,0" Margin="0,0,0,1" Padding="16,12">
                                    <Grid>
                                        <TextBlock Text="Hardware Telemetry" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="0,0,8,8" Padding="16">
                                    <StackPanel>
                                        <!-- CPU / RAM Group -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <ui:FontIcon Glyph="&#xE734;" FontSize="16" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Processor &amp; Memory" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="CPU Usage" VerticalAlignment="Center" Opacity="0.8"/>
                                                    <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding Config.ShowCpu, Mode=TwoWay}" OnContent="" OffContent="" Margin="10,0,0,0" />
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="RAM Usage" VerticalAlignment="Center" Opacity="0.8"/>
                                                    <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding Config.ShowRam, Mode=TwoWay}" OnContent="" OffContent="" Margin="10,0,0,0" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <ui:FontIcon Glyph="&#xE7AD;" FontSize="16" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Graphics &amp; Thermals" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="GPU Usage" VerticalAlignment="Center" Opacity="0.8"/>
                                                    <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding Config.ShowGpu, Mode=TwoWay}" OnContent="" OffContent="" Margin="10,0,0,0" />
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="GPU Temperature" VerticalAlignment="Center" Opacity="0.8"/>
                                                    <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding Config.ShowTemp, Mode=TwoWay}" OnContent="" OffContent="" Margin="10,0,0,0" />
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <Separator Background="{DynamicResource SystemControlElevationBorderBrush}" Margin="0,8,0,16" />

                                        <!-- Net / Disk Group -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <ui:FontIcon Glyph="&#xE774;" FontSize="16" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Data &amp; Connectivity" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Upload Speed" VerticalAlignment="Center" Opacity="0.8"/>
                                                    <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding Config.ShowNetUp, Mode=TwoWay}" OnContent="" OffContent="" Margin="10,0,0,0" />
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Download Speed" VerticalAlignment="Center" Opacity="0.8"/>
                                                    <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding Config.ShowNetDown, Mode=TwoWay}" OnContent="" OffContent="" Margin="10,0,0,0" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <ui:FontIcon Glyph="&#xE7C1;" FontSize="16" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Storage Activity" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Used Space %" VerticalAlignment="Center" Opacity="0.8"/>
                                                    <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding Config.ShowDisk, Mode=TwoWay}" OnContent="" OffContent="" Margin="10,0,0,0" />
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Real-time Activity" VerticalAlignment="Center" Opacity="0.8"/>
                                                    <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding Config.ShowDiskSpeed, Mode=TwoWay}" OnContent="" OffContent="" Margin="10,0,0,0" />
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Right: Hardware Selection & Advanced -->
                            <StackPanel Grid.Column="2">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Hardware Selection" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,16"/>
                                        
                                        <TextBlock Text="Network Adapter" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                        <ComboBox x:Name="NetAdapterCombo" SelectedValue="{Binding Config.NetworkAdapter, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Margin="0,0,0,16">
                                            <ComboBoxItem Content="Default" />
                                        </ComboBox>

                                        <TextBlock Text="Graphics Card" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                        <ComboBox x:Name="GpuAdapterCombo" SelectedValue="{Binding Config.GpuAdapter, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Margin="0,0,0,16">
                                            <ComboBoxItem Content="Default" />
                                        </ComboBox>

                                        <TextBlock Text="Storage Drives" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                        <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding DiskItems, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,8,8" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="AppearanceSection" Visibility="Collapsed">
                        <TextBlock Text="Appearance" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: Typography & Style -->
                            <StackPanel Grid.Column="0">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Typography" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                                        
                                        <TextBlock Text="Font Family" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValue="{Binding Config.FontFamily, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Margin="0,0,0,16">
                                            <ComboBoxItem Content="Segoe UI" />
                                            <ComboBoxItem Content="Segoe UI Variable Display" />
                                            <ComboBoxItem Content="Inter" />
                                            <ComboBoxItem Content="Roboto" />
                                            <ComboBoxItem Content="Consolas" />
                                        </ComboBox>

                                        <TextBlock Text="Display Mode" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValue="{Binding Config.DisplayStyle, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Margin="0,0,0,16">
                                            <ComboBoxItem Content="Text" />
                                            <ComboBoxItem Content="Compact" />
                                        </ComboBox>

                                        <ui:ToggleSwitch Header="Bold Text" IsOn="{Binding Config.IsTextBold, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Column 2: Color Palette -->
                            <StackPanel Grid.Column="2">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Color Palette" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                                        
                                        <TextBlock Text="Metric Accent" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,0,0,8"/>
                                        <Button HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,12" Click="ColorButton_Click" Tag="Accent">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="18" Height="18" CornerRadius="3" Background="{Binding Config.AccentColorHex}" BorderBrush="White" BorderThickness="1"/>
                                                <TextBlock Grid.Column="1" Text="Select Accent" Margin="8,0" VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                        </Button>

                                        <TextBlock Text="Label Tone" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,0,0,8"/>
                                        <Button HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,12" Click="ColorButton_Click" Tag="Label">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="18" Height="18" CornerRadius="3" Background="{Binding Config.LabelColorHex}" BorderBrush="White" BorderThickness="1"/>
                                                <TextBlock Grid.Column="1" Text="Select Label" Margin="8,0" VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                        </Button>

                                        <TextBlock Text="Capsule Color" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,0,0,8"/>
                                        <Button HorizontalAlignment="Stretch" Height="36" Click="ColorButton_Click" Tag="Pod">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="18" Height="18" CornerRadius="3" Background="{Binding Config.PodColorHex}" BorderBrush="White" BorderThickness="1"/>
                                                <TextBlock Grid.Column="1" Text="Select Capsule" Margin="8,0" VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Column 3: Scaling & Background -->
                            <StackPanel Grid.Column="4">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Dashboard" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                                        <TextBlock Text="Scaling (Size)" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                        <Slider Minimum="0.5" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Value="{Binding Config.ScaleFactor, Mode=TwoWay}" Margin="0,0,0,12"/>

                                        <ui:ToggleSwitch Header="Enable Capsules" IsOn="{Binding Config.ShowPods, Mode=TwoWay}" Margin="0,0,0,8" />
                                        
                                        <ui:ToggleSwitch Header="Background Plate" IsOn="{Binding Config.ShowBackground, Mode=TwoWay}" Margin="0,0,0,8" />
                                        
                                        <Button HorizontalAlignment="Stretch" Height="32" Click="ColorButton_Click" Tag="Background" 
                                                Visibility="{Binding Config.ShowBackground, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="18" Height="18" CornerRadius="3" Background="{Binding Config.BackgroundColorHex}" BorderBrush="White" BorderThickness="1"/>
                                                <TextBlock Grid.Column="1" Text="Select Plate Color" Margin="8,0" VerticalAlignment="Center" FontSize="11"/>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Action Buttons -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="8" Margin="0,24,0,0" Padding="16">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="ResetDefaultsBtn" Click="ResetToDefaults_Click" Padding="16,8" ui:ControlHelper.CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Refresh" Margin="0,0,8,0" />
                                        <TextBlock Text="Reset Appearance" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- About Section -->
                    <StackPanel x:Name="AboutSection" Visibility="Collapsed">
                        <TextBlock Text="About" Foreground="#00CCFF" FontSize="20" Margin="0,0,0,16"/>
                        
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Kil0bit System Monitor" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="{Binding AppVersion}" Opacity="0.7" FontSize="13"/>
                            <TextBlock Text="A lightweight, high-performance system monitoring overlay designed for power users. Built with WPF and GDI+ rendering." 
                                       TextWrapping="Wrap" MaxWidth="600" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Separator Background="#1AFFFFFF" Margin="0,10"/>

                        <TextBlock Text="Connect with the Developer" FontWeight="SemiBold" FontSize="16" Margin="0,20,0,12"/>
                        
                        <UniformGrid Columns="2" HorizontalAlignment="Left">
                            <ui:HyperlinkButton Content="YouTube (@kilObit)" NavigateUri="https://www.youtube.com/@kilObit" FontSize="14" Margin="0,0,16,10"/>
                            <ui:HyperlinkButton Content="GitHub (kil0bit-kb)" NavigateUri="https://github.com/kil0bit-kb" FontSize="14" Margin="0,0,0,10"/>
                            <ui:HyperlinkButton Content="Blog (kil0bit.blogspot.com)" NavigateUri="https://kil0bit.blogspot.com/" FontSize="14" Margin="0,0,16,10"/>
                            <ui:HyperlinkButton Content="X (@kil0bit)" NavigateUri="https://x.com/kil0bit" FontSize="14" Margin="0,0,0,10"/>
                            <ui:HyperlinkButton Content="Support Me (Patreon)" NavigateUri="https://www.patreon.com/cw/KB_kilObit" FontSize="14" Margin="0,0,16,10"/>
                        </UniformGrid>

                        <StackPanel Margin="0,30,0,0" Opacity="0.6">
                            <TextBlock Text="Built with ❤️ by KB - kil0bit" HorizontalAlignment="Center" FontSize="12"/>
                            <TextBlock Text="© 2026 Kil0bit System Monitor" HorizontalAlignment="Center" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </ui:NavigationView>

        <!-- Footer -->
        <Border Grid.Row="1" Padding="24,16" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="QuitBtn" Grid.Column="0" Content="Quit Application" Click="QuitButton_Click" 
                        Style="{StaticResource AccentButtonStyle}"
                        Background="#D32F2F" Foreground="White" 
                        HorizontalAlignment="Left" Padding="16,8" ui:ControlHelper.CornerRadius="4"/>
                
                <Button x:Name="ResetAppBtn" Grid.Column="1" Click="ResetApp_Click" 
                        Foreground="#FF6666"
                        HorizontalAlignment="Center" Padding="16,8" ui:ControlHelper.CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Refresh" Margin="0,0,8,0" />
                        <TextBlock Text="Reset All Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SaveCloseBtn" Grid.Column="2" Content="Save &amp; Close" Click="SaveButton_Click" 
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Right" Padding="24,8" ui:ControlHelper.CornerRadius="4"/>
            </Grid>
        </Border>
    </Grid>
</Window>
