<Window
    x:Class="Kil0bitSystemMonitor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Kil0bitSystemMonitor"
    mc:Ignorable="d"
    Title="Kil0bit System Monitor">

    <Grid x:Name="RootGrid" Background="#010101" Padding="5,0"
          PointerPressed="RootGrid_PointerPressed"
          PointerReleased="RootGrid_PointerReleased"
          PointerMoved="RootGrid_PointerMoved"
          RightTapped="RootGrid_RightTapped">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="20" /> <!-- Spacing -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Net Up & CPU -->
        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="4"
                    Visibility="{Binding Config.ShowNetUp, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="↑:" Foreground="{Binding TextColor}" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Metrics.NetUpText}" Foreground="{Binding TextColor}" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="4"
                    Visibility="{Binding Config.ShowCpu, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="CPU:" Foreground="{Binding TextColor}" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Metrics.CpuUsage, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:F0} %'}" 
                       Foreground="{Binding TextColor}" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Net Down & MEM -->
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="4"
                    Visibility="{Binding Config.ShowNetDown, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="↓:" Foreground="{Binding TextColor}" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Metrics.NetDownText}" Foreground="{Binding TextColor}" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Spacing="4"
                    Visibility="{Binding Config.ShowRam, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="MEM:" Foreground="{Binding TextColor}" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Metrics.RamPercent, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:F0} %'}" 
                       Foreground="{Binding TextColor}" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
