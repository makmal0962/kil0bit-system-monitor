<?xml version='1.0' encoding='utf-8'?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
    
    <Package Name="Kil0bit System Monitor"
             Manufacturer="KB - kil0bit"
             Version="2.0.0"
             UpgradeCode="E3B0C442-98FC-1C14-9AFB-D36F9B6D7F3A"
             Language="1033">

        <SummaryInformation Keywords="Installer" Description="Kil0bit System Monitor — Advanced Hardware Telemetry Overlay" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of Kil0bit System Monitor is already installed." />

        <Media Id="1" Cabinet="kil0bit.cab" EmbedCab="yes" />

        <StandardDirectory Id="DesktopFolder">
            <Component Id="ApplicationDesktopShortcut" Guid="a63d9196-b88d-4ce8-84da-aff24a55fea9">
                <Shortcut Id="DesktopShortcut"
                          Name="Kil0bit System Monitor"
                          Description="Advanced Hardware Telemetry Overlay"
                          Target="[APPLICATIONFOLDER]Kil0bitSystemMonitor.exe"
                          WorkingDirectory="APPLICATIONFOLDER" />
                <RegistryValue Root="HKCU" Key="Software\Kil0bit\SystemMonitor" Name="desktop_shortcut" Type="integer" Value="1" KeyPath="yes" />
            </Component>
        </StandardDirectory>

        <StandardDirectory Id="LocalAppDataFolder">
            <Directory Id="APPLICATIONFOLDER" Name="Kil0bit System Monitor">
                <Component Id="MainExecutable" Guid="361a51d9-da54-479a-8e4e-2db359f5fbae">
                    <File Id="Kil0bitEXE"
                          Name="Kil0bitSystemMonitor.exe"
                          Source="publish\Kil0bitSystemMonitor.exe" />
                    <RemoveFile Id="PurgeAppFolder" Name="*.*" On="uninstall" />
                    <RegistryValue Root="HKCU" Key="Software\Kil0bit\SystemMonitor" Name="installed_exe" Type="integer" Value="1" KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="Kil0bit System Monitor">
                <Component Id="ApplicationShortcut" Guid="9e1c9496-a88d-4ce8-84da-aff24a55fea8">
                    <Shortcut Id="ApplicationStartMenuShortcut"
                              Name="Kil0bit System Monitor"
                              Description="Advanced Hardware Telemetry Overlay"
                              Target="[APPLICATIONFOLDER]Kil0bitSystemMonitor.exe"
                              WorkingDirectory="APPLICATIONFOLDER" />
                    <RemoveFolder Id="CleanUpShortCut" On="uninstall" />
                    <RegistryValue Root="HKCU" Key="Software\Kil0bit\SystemMonitor" Name="installed" Type="integer" Value="1" KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <Feature Id="Main">
            <ComponentRef Id="MainExecutable" />
            <ComponentRef Id="ApplicationShortcut" />
            <ComponentRef Id="ApplicationDesktopShortcut" />
        </Feature>

        <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="APPLICATIONFOLDER" />
    </Package>
</Wix>
