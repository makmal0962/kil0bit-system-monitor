<?xml version='1.0' encoding='windows-1252'?>
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
  <Product
    Id='*'
    Name='Kil0bit System Monitor'
    UpgradeCode='E3B0C442-98FC-1C14-9AFB-D36F9B6D7F3A'
    Manufacturer='KB - kil0bit'
    Language='1033'
    Codepage='1252'
    Version='!(bind.FileVersion.Kil0bitEXE)'>

    <Package
      Id='*'
      Keywords='Installer'
      Description='Kil0bit System Monitor — Advanced Hardware Telemetry Overlay'
      Manufacturer='KB - kil0bit'
      InstallerVersion='450'
      Languages='1033'
      Compressed='yes'
      InstallScope='perUser'
      SummaryCodepage='1252'/>

    <MajorUpgrade
      Schedule='afterInstallInitialize'
      DowngradeErrorMessage='A newer version of Kil0bit System Monitor is already installed.'/>

    <Media Id='1' Cabinet='kil0bit.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
    <Property Id='DiskPrompt' Value='Kil0bit System Monitor Installation'/>
    <Property Id='WIXUI_INSTALLDIR' Value='APPLICATIONFOLDER' />
    
    <!-- Using simplistic UI for per-user install -->
    <UIRef Id='WixUI_InstallDir' />
    
    <!-- We skip the license rtf to keep it lean, or keep placeholder -->
    <WixVariable Id='WixUILicenseRtf' Value='GUIDE.md' Condition='false' />

    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='DesktopFolder' Name='Desktop'>
        <Component Id='ApplicationDesktopShortcut' Guid='a63d9196-b88d-4ce8-84da-aff24a55fea9'>
          <Shortcut
            Id='DesktopShortcut'
            Name='Kil0bit System Monitor'
            Description='Advanced Hardware Telemetry Overlay'
            Target='[APPLICATIONFOLDER]\Kil0bitSystemMonitor.exe'
            WorkingDirectory='APPLICATIONFOLDER'/>
          <RegistryValue
            Root='HKCU'
            Key='Software\Kil0bit\SystemMonitor'
            Name='desktop_shortcut'
            Type='integer'
            Value='1'
            KeyPath='yes'/>
        </Component>
      </Directory>
      
      <Directory Id='LocalAppDataFolder'>
        <Directory Id='APPLICATIONFOLDER' Name='Kil0bit System Monitor'>
          <Component Id='MainExecutable' Guid='361a51d9-da54-479a-8e4e-2db359f5fbae'>
            <File
              Id='Kil0bitEXE'
              Name='Kil0bitSystemMonitor.exe'
              DiskId='1'
              Source='publish\Kil0bitSystemMonitor.exe'/>
            
            <RemoveFile Id='PurgeAppFolder' Name='*.*' On='uninstall'/>
            <RemoveFolder Id='RemoveAppFolder' On='uninstall'/>
            
            <RegistryValue
              Root='HKCU'
              Key='Software\Kil0bit\SystemMonitor'
              Name='installed_exe'
              Type='integer'
              Value='1'
              KeyPath='yes'/>
          </Component>
        </Directory>
      </Directory>

      <!-- Start Menu shortcut -->
      <Directory Id='ProgramMenuFolder'>
        <Directory Id='ApplicationProgramsFolder' Name='Kil0bit System Monitor'>
          <Component Id='ApplicationShortcut' Guid='9e1c9496-a88d-4ce8-84da-aff24a55fea8'>
            <Shortcut
              Id='ApplicationStartMenuShortcut'
              Name='Kil0bit System Monitor'
              Description='Advanced Hardware Telemetry Overlay'
              Target='[APPLICATIONFOLDER]\Kil0bitSystemMonitor.exe'
              WorkingDirectory='APPLICATIONFOLDER'/>
            <RemoveFolder Id='CleanUpShortCut' Directory='ApplicationProgramsFolder' On='uninstall'/>
            <RegistryValue
              Root='HKCU'
              Key='Software\Kil0bit\SystemMonitor'
              Name='installed'
              Type='integer'
              Value='1'
              KeyPath='yes'/>
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id='Complete' Level='1'>
      <ComponentRef Id='MainExecutable'/>
      <ComponentRef Id='ApplicationShortcut'/>
      <ComponentRef Id='ApplicationDesktopShortcut'/>
    </Feature>

  </Product>
</Wix>
